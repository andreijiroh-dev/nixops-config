{
  "languages": {
    "Nix": {
      "language_servers": ["nil", "!nixd"],
    },
  },
  "lsp": {
    "nil": {
      "initialization_options": {
        "formatting": {
          "command": ["nixfmt"],
        },
        "nix": {
          "flake": {
            "autoArchive": true,
            "autoEvalInputs": false,
            "nixpkgsInputName": "nixpkgs",
          },
        },
      },
    },
  },
  "git_hosting_providers": [
    {
      "base_url": "https://mau.dev",
      "provider": "gitlab",
      "name": "Manimum GitLab",
    },
  ],
}
